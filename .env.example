# Pir9 Environment Configuration
# Copy this to .env and adjust values as needed

# User/Group IDs for file permissions (match your host user)
PUID=1000
PGID=1000

# Timezone
TZ=America/New_York

# Path to your TV shows directory (for simple/standalone mode)
TV_SHOWS_PATH=/path/to/tv/shows

# =============================================================================
# Database Configuration
# =============================================================================

# SQLite (default) - just a file path
PIR9_DB_TYPE=sqlite
PIR9_DB_CONNECTION=/config/pir9.db

# PostgreSQL - uncomment and configure for production
# PIR9_DB_TYPE=postgres
# PIR9_DB_CONNECTION=postgresql://pir9:pir9@postgres:5432/pir9

# PostgreSQL credentials (used by postgres container)
POSTGRES_USER=pir9
POSTGRES_PASSWORD=pir9
POSTGRES_DB=pir9

# =============================================================================
# Synology Worker Configuration
# =============================================================================

# IP address of your Docker host running the server
SERVER_IP=10.0.0.13

# Redis port (6311 to avoid conflict with other Redis instances)
REDIS_PORT=6311

# =============================================================================
# External API Keys
# =============================================================================

# Fanart.tv API key — provides extra movie artwork (logo, clearart, banner, etc.)
# Get a free key at https://fanart.tv/get-an-api-key/
FANART_API=
